# apps/ai-engine/Dockerfile

# =========================
# BASE
# =========================

FROM node:20-alpine

# =========================
# WORKDIR
# =========================

WORKDIR /app

# =========================
# COPY PACKAGE
# =========================

COPY package*.json ./

# =========================
# INSTALL
# =========================

RUN npm install

# =========================
# COPY SOURCE
# =========================

COPY . .

# =========================
# BUILD
# =========================

RUN npm run build

# =========================
# EXPOSE
# =========================

EXPOSE 4000

# =========================
# START
# =========================

CMD ["node", "dist/apps/ai-engine/main.js"]