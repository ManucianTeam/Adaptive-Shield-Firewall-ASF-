{
  "name": "ai-engine",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",

  "engines": {
    "node": ">=20"
  },

  "scripts": {
    "start": "nest start ai-engine",

    "start:dev": "nest start ai-engine --watch",

    "start:debug": "nest start ai-engine --debug --watch",

    "start:prod": "node dist/apps/ai-engine/main.js",

    "build": "nest build ai-engine",

    "build:prod": "nest build ai-engine --webpack",

    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",

    "format": "prettier --write \"apps/**/*.ts\"",

    "test": "jest",

    "test:watch": "jest --watch",

    "test:cov": "jest --coverage",

    "clean": "rimraf dist",

    "docker:build": "docker build -t asf-ai-engine .",

    "docker:run": "docker run -p 4000:4000 asf-ai-engine"
  },

  "dependencies": {
    "@nestjs/cache-manager": "^3.1.2",

    "@nestjs/common": "^10.4.22",

    "@nestjs/config": "^3.3.0",

    "@nestjs/core": "^11.1.21",

    "@nestjs/event-emitter": "^3.1.0",

    "@nestjs/jwt": "^11.0.2",

    "@nestjs/mapped-types": "^2.1.0",

    "@nestjs/mongoose": "^11.0.4",

    "@nestjs/passport": "^11.0.5",

    "@nestjs/platform-express": "^11.1.21",

    "@nestjs/throttler": "^6.5.0",

    "@nestjs/typeorm": "^10.0.2",

    "bcrypt": "^6.0.0",

    "cache-manager": "^6.4.3",

    "class-transformer": "^0.5.1",

    "class-validator": "^0.14.1",

    "compression": "^1.8.1",

    "cookie-parser": "^1.4.7",

    "express": "^4.21.2",

    "express-rate-limit": "^8.1.0",

    "helmet": "^8.1.0",

    "ioredis": "^5.8.1",

    "mongoose": "^8.18.0",

    "passport": "^0.7.0",

    "passport-jwt": "^4.0.1",

    "passport-local": "^1.0.0",

    "pg": "^8.16.3",

    "redis": "^5.8.2",

    "reflect-metadata": "^0.2.2",

    "rxjs": "^7.8.2",

    "typeorm": "^0.3.26"
  },

  "devDependencies": {
    "@nestjs/cli": "^10.4.9",

    "@nestjs/schematics": "^10.1.4",

    "@nestjs/testing": "^11.1.21",

    "@types/bcrypt": "^6.0.0",

    "@types/compression": "^1.8.1",

    "@types/cookie-parser": "^1.4.9",

    "@types/express": "^5.0.3",

    "@types/jest": "^29.5.14",

    "@types/node": "^22.18.6",

    "@types/passport-jwt": "^4.0.1",

    "@types/passport-local": "^1.0.38",

    "@types/supertest": "^6.0.3",

    "@typescript-eslint/eslint-plugin": "^8.44.1",

    "@typescript-eslint/parser": "^8.44.1",

    "eslint": "^9.35.0",

    "eslint-config-prettier": "^10.1.8",

    "eslint-plugin-prettier": "^5.5.4",

    "jest": "^29.7.0",

    "prettier": "^3.6.2",

    "rimraf": "^6.0.1",

    "supertest": "^7.1.4",

    "ts-jest": "^29.4.1",

    "ts-loader": "^9.5.4",

    "ts-node": "^10.9.2",

    "tsconfig-paths": "^4.2.0",

    "typescript": "^5.9.2"
  },

  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],

    "rootDir": ".",

    "testRegex": ".*\\.spec\\.ts$",

    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },

    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],

    "coverageDirectory": "./coverage",

    "testEnvironment": "node",

    "moduleNameMapper": {
      "^src/(.*)$": "<rootDir>/src/$1"
    }
  }
}
