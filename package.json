{
  "name": "adaptive-shield-firewall-asf",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start:gateway": "cd apps/gateway && nest start --watch",
    "start:ai": "cd apps/ai-engine && nest start --watch",
    "start:all": "npm-run-all --parallel start:gateway start:ai",
    "dev:ai": "cd apps/ai-engine && nest start --watch",
    "dev:gateway": "cd apps/gateway && nest start --watch",
    "dev": "npm-run-all --parallel dev:ai dev:gateway",
    "build": "npx nest build",
    "test": "jest"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "npm-run-all": "^4.1.5"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  }
}
